{
	"name": "what-to-eat",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "npm run dev:api & npm run dev:web",
		"dev:web": "npm run dev -w @what-to-eat/web",
		"dev:api": "npm run dev -w @what-to-eat/api",
		"build:web": "npm run build -w @what-to-eat/web",
		"build:api": "npm run build -w @what-to-eat/api",
		"test": "npm run test --workspaces --if-present",
		"lint": "npm run lint --workspaces --if-present",
		"format": "npm run format --workspaces --if-present"
	}
}
