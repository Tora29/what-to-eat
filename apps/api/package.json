{
	"name": "@what-to-eat/api",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "wrangler dev --config wrangler.local.jsonc",
		"deploy": "wrangler deploy",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "eslint src",
		"format": "prettier --write src",
		"db:generate": "prisma generate --no-engine",
		"db:migrate": "wrangler d1 execute what-to-eat --local --file=prisma/schema.sql",
		"db:seed": "wrangler d1 execute what-to-eat --local --file=prisma/seed.sql",
		"db:setup": "npm run db:migrate && npm run db:seed"
	},
	"dependencies": {
		"@prisma/adapter-d1": "^6.0.0",
		"@prisma/client": "^6.0.0",
		"@what-to-eat/constants": "*",
		"@what-to-eat/shared": "*",
		"better-auth": "^1.0.0",
		"hono": "^4.0.0",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.0.0",
		"@hono/standard-validator": "^0.1.0",
		"@eslint/js": "^9.0.0",
		"@typescript-eslint/eslint-plugin": "^8.0.0",
		"@typescript-eslint/parser": "^8.0.0",
		"eslint": "^9.0.0",
		"eslint-config-prettier": "^10.0.0",
		"prettier": "^3.0.0",
		"prisma": "^6.0.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0",
		"wrangler": "^4.0.0"
	}
}
