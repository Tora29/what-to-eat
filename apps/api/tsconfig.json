{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"noUncheckedIndexedAccess": true,
		"lib": ["ESNext"],
		"types": ["@cloudflare/workers-types"]
	},
	"include": ["src", "prisma"],
	"exclude": ["node_modules", "dist"]
}
